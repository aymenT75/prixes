# ── Prixes production env ───────────────────────────────────────────
# Copy to .env.production, set DOMAIN, then run ./scripts/gen-secrets.sh
# to fill the SECRET_* / password fields with strong random values.

ENVIRONMENT=production

# Public domain (DNS must point here for HTTPS to be issued by Let's Encrypt).
DOMAIN=prixes.example.com
PUBLIC_BASE_URL=https://prixes.example.com
WEB_BASE_URL=https://prixes.example.com
API_BASE_URL=https://prixes.example.com
# Same-origin in production (browser hits https://domain/api/v1 via Caddy).
NEXT_PUBLIC_API_BASE_URL=https://prixes.example.com
# Only the real origin may call the API.
CORS_ORIGINS=https://prixes.example.com

# ── Secrets — DO NOT commit. Filled by scripts/gen-secrets.sh ────────
SECRET_KEY=__generate__
NEXTAUTH_SECRET=__generate__
NEXTAUTH_URL=https://prixes.example.com

# ── Database (PostgreSQL + PostGIS) ─────────────────────────────────
POSTGRES_USER=prixes
POSTGRES_PASSWORD=__generate__
POSTGRES_DB=prixes
# Host is the compose service name "db".
DATABASE_URL=postgresql+asyncpg://prixes:__generate__@db:5432/prixes

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Auth ────────────────────────────────────────────────────────────
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Firebase project id (public) — verifies client ID tokens incl. native Apple/Google.
FIREBASE_PROJECT_ID=prixes-b07fb

# ── Push notifications (FCM, for the native apps) ───────────────────
# Service account with "Firebase Cloud Messaging API" access. Provide EITHER a path
# to the mounted JSON file OR the JSON inline. Leave blank to disable push (price
# alerts still show in-app). Upload the APNs .p8 key in the Firebase console for iOS.
FIREBASE_SERVICE_ACCOUNT_FILE=/run/secrets/fcm-service-account.json
FIREBASE_SERVICE_ACCOUNT_JSON=
# CORS: the fixed Capacitor native origins are always allowed automatically.
NEXT_PUBLIC_FIREBASE_API_KEY=

# ── Object storage (S3 / Cloudflare R2) — needed for deal photo uploads.
# Leave blank to disable photo uploads (the UI hides the photo field).
S3_ENDPOINT_URL=
S3_BUCKET=prixes-photos
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ── Upstream open-data APIs ─────────────────────────────────────────
OFF_BASE_URL=https://world.openfoodfacts.org
OPENPRICES_BASE_URL=https://prices.openfoodfacts.org/api
FUEL_DATA_URL=https://donnees.roulez-eco.fr/opendata/instantane

# ── Observability (optional) ────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
