# Environment for native (Capacitor) builds — loaded by `npm run build:mobile` via dotenv-cli.
# These are NOT secrets: the API URL is public and the Firebase web config is public by design.

# Emit a static `out/` bundle (see next.config.mjs).
BUILD_TARGET=mobile

# Native bundles ship inside the iOS/Android app and call the live production API over HTTPS.
NEXT_PUBLIC_API_BASE_URL=https://prixes.omnilink.software
