# ── App ───────────────────────────────────────────────────────────
ENVIRONMENT=local                 # local | staging | production
SECRET_KEY=change-me-in-prod-use-openssl-rand-hex-32
API_BASE_URL=http://localhost:8000
WEB_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# ── Database (PostgreSQL + PostGIS) ───────────────────────────────
POSTGRES_USER=prixes
POSTGRES_PASSWORD=prixes
POSTGRES_DB=prixes
DATABASE_URL=postgresql+asyncpg://prixes:prixes@localhost:5432/prixes

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Auth ──────────────────────────────────────────────────────────
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_DAYS=30
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Object storage (S3 / Cloudflare R2) ───────────────────────────
S3_ENDPOINT_URL=
S3_BUCKET=prixes-photos
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# ── Upstream open-data APIs ───────────────────────────────────────
OFF_BASE_URL=https://world.openfoodfacts.org
OPENPRICES_BASE_URL=https://prices.openfoodfacts.org/api
FUEL_DATA_URL=https://donnees.roulez-eco.fr/opendata/instantane

# ── Observability ─────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO

# ── Web (Next.js) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXTAUTH_SECRET=change-me
NEXTAUTH_URL=http://localhost:3000
