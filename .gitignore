# ── Secrets & env (NEVER commit real values) ──
.env
.env.*
!.env.example
!.env.production.example
!.env.local.example
# Not a secret: only BUILD_TARGET=mobile + the public API URL. It must be committed
# because `npm run build:mobile` loads it to emit the static `out/` bundle — without
# it, CI (and any fresh clone) cannot build the native app at all.
!.env.mobile
*.local
sa.json

# ── Android release signing (NEVER commit — losing OR leaking the keystore is fatal) ──
*.keystore
*.jks
keystore.properties
serviceAccount*.json
dump.json

# ── Dependencies / build output ──
node_modules/
.next/
out/
build/
dist/
*.tsbuildinfo
next-env.d.ts

# ── Python ──
__pycache__/
*.py[cod]
.venv/
venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
*.egg-info/

# ── Tooling / local ──
.claude/
.DS_Store
Thumbs.db
*.log

# ── Deploy artifacts ──
*.tar.gz
*.tar
caddy_data/
pgdata/
